# ── PROVIDERS (dev fallback only) ──────────────────────────────────────────
# In multi-tenant mode each user supplies their own keys via /settings.
# These server-side keys are only used when PARLOIR_DEV_INHERIT_ENV=1.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional local model endpoints (also used as defaults by the dev shim).
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
VLLM_BASE_URL=

# ── DATABASE ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=parloir_dev
DATABASE_URL=postgres://parloir:parloir_dev@localhost:5432/parloir

# ── DURABLE EXECUTION ──────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── OBSERVABILITY (optional) ───────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── APP ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AUTH ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── CREDENTIALS ENCRYPTION ─────────────────────────────────────────────────
# AES-256-GCM key for per-user stored provider keys. 32 bytes, base64.
# Generate: openssl rand -base64 32
# Do NOT change after credentials are stored — ciphertext becomes unreadable.
PARLOIR_ENCRYPTION_KEY=

# ── DEV SHIM ───────────────────────────────────────────────────────────────
# If 1, registry falls back to server-side env keys above when the current
# user hasn't connected that provider. Unset in multi-tenant deployments.
PARLOIR_DEV_INHERIT_ENV=
