# ── PROVIDERS ──────────────────────────────────────────────────────────────
# OpenRouter is the default and strongly recommended gateway (300+ models, one key).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: direct provider keys for BYOK / lower latency on critical paths.
# If set, the provider registry prefers them over OpenRouter for those models.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: local model endpoints.
# Ollama default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
# LM Studio default: http://localhost:1234/v1 (OpenAI-compatible)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# vLLM — any OpenAI-compatible endpoint
VLLM_BASE_URL=

# ── DATABASE ───────────────────────────────────────────────────────────────
# Postgres with pgvector extension. Neon, Supabase, or local docker compose all work.
# POSTGRES_PASSWORD is required by docker-compose.yml — change it for anything beyond local dev.
POSTGRES_PASSWORD=parloir_dev
DATABASE_URL=postgres://parloir:parloir_dev@localhost:5432/parloir

# ── DURABLE EXECUTION ──────────────────────────────────────────────────────
# Inngest handles long-running debate workflows (bypasses Vercel's 300s limit).
# Leave these empty for local dev — the Inngest dev server auto-discovers.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── OBSERVABILITY (optional) ───────────────────────────────────────────────
# Langfuse for tracing multi-agent flows. Self-hostable.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── APP ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AUTH ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=  # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# ── ENCRYPTION ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
PARLOIR_ENCRYPTION_KEY=
